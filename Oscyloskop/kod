#include <Servo.h>

Servo myServo;

const int potPin = A0;
const int servoPin = 3;

void setup() {
  myServo.attach(servoPin);
}

void loop() {
  int potValue = analogRead(potPin);

  int angle = map(potValue, 0, 1023, 0, 180); // 1023 bo 10 bitowe, 180 to rotacja maksymalna

  myServo.write(angle);

  delay(10);
}
